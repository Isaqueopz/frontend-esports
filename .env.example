# ⚠️ SPRING BOOT API Configuration
# Copie este arquivo para .env.local e configure as variáveis

# URL base da API Spring Boot
VITE_API_URL=http://localhost:8080/api

# WebSocket URL para updates em tempo real
VITE_WS_URL=ws://localhost:8080/ws

# Configurações de desenvolvimento
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# Configurações de autenticação (quando implementada)
# VITE_AUTH_ENABLED=false
# VITE_JWT_SECRET=your-secret-key

# Configurações de logging
VITE_LOG_LEVEL=debug